# Supabase — REQUIRED for cloud sync (profiles, IPTV accounts, watch history, favorites).
# Without these, isSupabaseConfigured() is false and the app silently falls back to
# device-local storage, so a build (e.g. web/Electron) won't see cloud data created
# on other platforms. Copy this file to `.env` and fill in your project's values.
#
# These are PUBLIC client keys (safe to embed in the app bundle). The anon key is
# row-level-security gated — do NOT put the service_role key here.
#
# Expo inlines any EXPO_PUBLIC_* var at build/export time (npm run web / build:web /
# build:electron). `.env` is gitignored; this `.env.example` is the committed template.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# TMDB — used by src/services/tmdbApi.js for Movies/Series artwork & metadata.
# When absent, tmdbApi.hasKey is false and VOD enrichment is skipped (the app
# still works, just without posters/backdrops from TMDB). Also an EXPO_PUBLIC_*
# key inlined at build/export time.
EXPO_PUBLIC_TMDB_API_KEY=your-tmdb-api-key
