{
  "appId": "com.andrew1h1.iptvplayer",
  "productName": "Lumen IPTV Player",
  "asar": true,
  "afterPack": "electron/afterPack.js",
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "files": [
    "dist/**",
    "electron/main.js",
    "electron/preload.js",
    "electron/vlcInvocation.js"
  ],
  "directories": {
    "buildResources": "electron/assets",
    "output": "electron/release"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "allowElevation": false,
    "installerSidebar": "electron/assets/installerSidebar.bmp",
    "installerHeader": "electron/assets/installerHeader.bmp"
  },
  "mac": {
    "target": "dmg"
  },
  "dmg": {
    "background": "electron/assets/background.png",
    "iconSize": 96,
    "window": { "width": 660, "height": 400 },
    "contents": [
      { "x": 165, "y": 285, "type": "file" },
      { "x": 495, "y": 285, "type": "link", "path": "/Applications" }
    ]
  },
  "linux": {
    "target": "AppImage",
    "executableName": "iptv-player"
  }
}
