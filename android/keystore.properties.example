# Release signing credentials for Suvo — COPY to `keystore.properties` (same
# folder) and fill in real values. `keystore.properties` is gitignored; never
# commit it or the keystore itself. See docs/RELEASE_SIGNING.md.
#
# storeFile is resolved relative to the android/app/ directory.
storeFile=suvo-release.keystore
storePassword=CHANGE_ME
keyAlias=suvo
keyPassword=CHANGE_ME
