+// resizeMode maps RN's "contain"/"cover"/"fill" onto VLCKit's aspect/crop knobs,
+// computed against the view's own bounds so the video fills exactly:
+//   contain -> default fit (letterbox, aspect preserved)
+//   cover   -> crop to the view's aspect ratio (fills, aspect preserved, edges cropped)
+//   fill    -> force the display aspect ratio to the view's (fills, stretched)
+- (void)setResizeMode:(NSString *)mode{
+    _resizeMode = mode;
+    [self applyResizeMode];
+}
+
+- (void)applyResizeMode{
+    if (!_player) return;
+    CGSize size = self.bounds.size;
+    if (size.width <= 0 || size.height <= 0) return;
+    // Only the ratio matters to VLC, so integer points are fine.
+    NSString *ratio = [NSString stringWithFormat:@"%d:%d", (int)round(size.width), (int)round(size.height)];
+
+    if ([_resizeMode isEqualToString:@"fill"]) {
+        _player.scaleFactor = 0;
+        _player.videoCropGeometry = NULL;
+        [_player setVideoAspectRatio:(char *)[ratio cStringUsingEncoding:NSASCIIStringEncoding]];
+    } else if ([_resizeMode isEqualToString:@"cover"]) {
+        _player.scaleFactor = 0;
+        [_player setVideoAspectRatio:NULL];
+        _player.videoCropGeometry = (char *)[ratio cStringUsingEncoding:NSASCIIStringEncoding];
+    } else {
+        // contain (default)
+        _player.scaleFactor = 0;
+        [_player setVideoAspectRatio:NULL];
+        _player.videoCropGeometry = NULL;
+    }
+}
+
+- (void)layoutSubviews{
+    [super layoutSubviews];
+    // Re-apply on bounds changes (rotation, fullscreen toggle) so cover/fill
+    // stay matched to the current view size.
+    [self applyResizeMode];
+}
