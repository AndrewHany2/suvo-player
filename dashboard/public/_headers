# Security response headers for the built dashboard. Netlify / Cloudflare Pages
# read this file (Vite copies public/ verbatim into dist/). If you host
# elsewhere, send the SAME headers from your server (nginx add_header, a Vercel
# `headers` route, etc.) — the CSP's frame-ancestors + X-Frame-Options can only
# come from real response headers, not a <meta> tag.
#
# The dashboard is the highest-privilege surface (super-admin / provider) and
# keeps its Supabase session token in localStorage, so an XSS would be
# catastrophic — a strict CSP is the practical mitigation. Verify against the
# built bundle with `npm run build && npm run preview` before deploying: if the
# build emits an inline bootstrap script, either set
# build.modulePreload.polyfill=false or add its hash to script-src rather than
# weakening the policy with 'unsafe-inline'.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://*.supabase.co; form-action 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains
